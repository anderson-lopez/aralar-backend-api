# Configuración de Flask
FLASK_ENV=production
SECRET_KEY=change_this_in_prod_super_secret_key_here
JWT_SECRET_KEY=change_this_jwt_secret_key_here

# Base de datos MongoDB
# Para Docker: usar el nombre del servicio 'mongo'
# Para desarrollo local: usar 'localhost'
MONGO_URI=mongodb://mongo:27017/aralar

# CORS - Orígenes permitidos (separados por comas)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Rate limiting
RATE_LIMIT_DEFAULT=100/hour

# Seguridad
SECURE_COOKIES=false
TALISMAN_FORCE_HTTPS=false

# Datos iniciales del administrador
SEED_ADMIN_EMAIL=admin@aralar.local
SEED_ADMIN_PASSWORD=ChangeMeNow!2025
SEED_ADMIN_FULLNAME="Admin Aralar"

# Configuración de traducción (opcional)
I18N_PROVIDER=deepl
DEEPL_API_KEY=

# Configuración S3/Object Storage (opcional - no necesario para funcionamiento básico)
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY=minio
# S3_SECRET_KEY=minio123
# S3_REGION=us-east-1
# S3_BUCKET=aralar-media